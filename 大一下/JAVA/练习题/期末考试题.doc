					</w:rPr>
					<w:t>阅读下列代码<w:br/>import java.io.*;<w:br/>import java.util.*;<w:br/>class Example {<w:br/>    public static void main(String[] args) throws IOException {<w:br/>    /*<w:br/> 使用io包中的SequenceInputStream，对碎片文件进行合并，<w:br/>将多个读取流合并成一个读取流。<w:br/>*/<w:br/>        List&lt;FileInputStream&gt; list = new ArrayList&lt;FileInputStream&gt;();<w:br/>        for (int i = 1; i &lt; 7; i++) {<w:br/>            list.add(new FileInputStream(i + ".part"));<w:br/>        }<w:br/>    /*<w:br/> 怎么获取枚举对象呢？List自身是无法获取枚举Enumeration对象的，<w:br/>考虑到Collections中去找。<w:br/>    */<w:br/>        _________&lt;FileInputStream&gt; en = Collections.enumeration(list);<w:br/>        // 源。<w:br/>        SequenceInputStream sis = new SequenceInputStream(en);<w:br/>        // 目的。<w:br/>        FileOutputStream fos = new FileOutputStream("itcast.png");<w:br/>        // 不断的读写。<w:br/>        byte[] buf = new byte[4096];<w:br/>        int len = 0;<w:br/>        while ((len = sis.read(buf)) != -1) {<w:br/>            fos.write(buf, 0, len);<w:br/>        }<w:br/>        fos.close();<w:br/>        sis.close();<w:br/>    }<w:br/>}<w:br/>写出在横线上应该填写的方法名称(   )<w:br/><w:br/></w:t>
				</w:r>
			</w:p>
