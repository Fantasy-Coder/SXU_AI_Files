					</w:rPr>
					<w:t> class Student {<w:br/>    public String name;<w:br/>    public int age;<w:br/>    public Student(String name,int age){<w:br/>        this.name=name;<w:br/>        this.age=age;<w:br/>    }<w:br/>    public void show(){<w:br/>        System.out.println("name: "+name+" age: "+age);<w:br/>    }<w:br/>}<w:br/>class UnderGraduate extends Student{<w:br/>    public String degree;<w:br/>    public UnderGraduate(String name,int age,String degree){<w:br/>        super(name, age);<w:br/>        this.degree=degree;<w:br/>    }<w:br/>    public void show(){<w:br/>        System.out.println("name: "+name+" age: "+age+" degree: "+degree);<w:br/>    }<w:br/>}<w:br/>public class Test01{<w:br/>    public static void main(String[] args) {<w:br/>        Student student = new Student("zhangsan", 16);<w:br/>        student.show();<w:br/>        UnderGraduate underGraduate = new UnderGraduate("lisi", 20, "bechalor");<w:br/>        underGraduate.show();<w:br/>    }<w:br/>}<w:br/><w:br/> </w:t>
				</w:r>
			</w:p>
