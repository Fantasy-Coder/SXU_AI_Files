				<w:r>
					<w:rPr>
						<w:rFonts w:hint="fareast" />
						<w:sz w:val="18" />
					</w:rPr>
					<w:t>多个类可以继承一个父类</w:t>
				</w:r>
			</w:p>
			 			<w:p wsp:rsidR="00000000" wsp:rsidRDefault="00016828">
