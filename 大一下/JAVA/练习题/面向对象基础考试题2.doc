			               <w:p wsp:rsidR="00000000" wsp:rsidRDefault="00016828">
				<w:pPr>
					<w:pStyle w:val="a5" />
					<w:spacing w:line="60" w:line-rule="auto" />
					<w:rPr>
						<w:rFonts w:hint="fareast" />
						<w:sz w:val="18" />
					</w:rPr>
